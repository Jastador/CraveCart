<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_blue">

    <!-- App Name -->
    <TextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CraveCart"
        android:textSize="50sp"
        android:textStyle="bold"
        android:fontFamily="@font/collegiateflf"
        android:textColor="@color/black"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp" />

    <!-- Email Field -->
    <EditText
        android:id="@+id/emailField"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Email"
        android:fontFamily="@font/monospacetypewriter"
        android:textSize="15sp"
        android:inputType="textEmailAddress"
        android:background="@drawable/rounded_edittext"
        android:padding="12dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="180dp" />

    <!-- Password Field -->
    <EditText
        android:id="@+id/passwordField"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="Password"
        android:fontFamily="@font/monospacetypewriter"
        android:textSize="15sp"
        android:inputType="textPassword"
        android:background="@drawable/rounded_edittext"
        android:padding="12dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/emailField"
        android:layout_marginTop="20dp" />

    <!-- Show Password -->
    <CheckBox
        android:id="@+id/showPasswordLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Show password"
        android:fontFamily="@font/verilyserifmono"
        android:textColor="@color/black"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/passwordField"
        android:layout_marginTop="10dp"/>


    <!-- Sign In Button -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Login"
        android:fontFamily="@font/verilyserifmono"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/showPasswordLogin"
        android:layout_marginTop="30dp"
        android:backgroundTint="@color/black"
        android:textColor="@color/funky_yellow"
        android:textStyle="bold"/>

    <!-- New User -->
    <Button
        android:id="@+id/newUser"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="New User?"
        android:fontFamily="@font/verilyserifmono"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/btnLogin"
        android:layout_marginTop="30dp"
        android:backgroundTint="@color/black"
        android:textColor="@color/funky_yellow"
        android:textStyle="bold" />

    <!-- Forgot Password -->
    <Button
        android:id="@+id/forgotPassword"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Forgot Password?"
        android:fontFamily="@font/verilyserifmono"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/newUser"
        android:layout_marginTop="30dp"
        android:backgroundTint="@color/black"
        android:textColor="@color/funky_yellow"
        android:textStyle="bold" />

</RelativeLayout>
