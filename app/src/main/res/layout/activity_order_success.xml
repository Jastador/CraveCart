<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:gravity="center"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/light_blue" android:padding="24dp">

    <TextView android:id="@+id/tvMsg" android:text="Order Confirmed!"
        android:textStyle="bold" android:textSize="22sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvOrder"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDone" android:text="Done"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp"/>
</LinearLayout>
